{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "noEmit": false,
    "rewriteRelativeImportExtensions": false
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "rules.config.ts"],
  "exclude": ["src/**/*.test.ts", "dist", "node_modules"]
}
