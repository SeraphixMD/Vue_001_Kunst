{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[@kunst/ui] You are in the library monorepo. Use .claude/skills/ to scaffold components. Never hand-write component files. Rule source of truth: packages/ui/rules.config.ts. Run pnpm verify:quick before declaring done.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/post-edit.sh \"$CLAUDE_FILE_PATHS\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/stop.sh"
          }
        ]
      }
    ]
  }
}
